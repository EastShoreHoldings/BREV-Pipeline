# Copy this file to .env.local and fill in the values.
# Netlify reads these same variable names from its dashboard env vars.

# --- Supabase (auth + deals storage) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# --- US Census Bureau (Demographics tab) ---
# Free key, sign up at https://api.census.gov/data/key_signup.html
VITE_CENSUS_API_KEY=your_census_api_key_here
